@model gestionStock.Models.Produit

@{
    ViewData["Title"] = "Modifier produit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Modifier produit</h2>
        <a asp-action="List" class="btn btn-outline-secondary">
            ← Retour à la liste
        </a>
    </div>

    <!-- Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <!-- Messages -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    
                    <!-- Nom -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Nom du produit</label>
                        <input asp-for="Libelle" class="form-control" placeholder="Ex: Ordinateur" />
                    </div>

                    <!-- Quantité -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Quantité</label>
                        <input asp-for="Quantite" type="number" class="form-control" min="0" />
                    </div>

                    <!-- Catégorie -->
                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-semibold">Catégorie</label>
                        <select asp-for="CategorieId" class="form-select">
                            @foreach (var cat in ViewBag.Categories)
                            {
                                <option value="@cat.Id" selected="@(cat.Id == Model.CategorieId)">
                                    @cat.Libelle
                                </option>
                            }
                        </select>
                    </div>

                </div>

                <!-- Boutons -->
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="List" class="btn btn-light border">
                        Annuler
                    </a>
                    <button type="submit" class="btn btn-success px-4">
                        Enregistrer
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>